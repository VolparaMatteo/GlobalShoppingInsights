# ============================================================================
# GSI — configurazione PRODUZIONE (docker-compose.prod.yml)
#
# Copia in `.env.prod` sul VPS (chmod 600) e compila TUTTI i valori marcati
# OBBLIGATORIO. Il backend rifiuta l'avvio se uno dei segreti è al default
# (vedi backend/app/config.py).
#
# Comandi per generare i valori crittografici:
#   SECRET_KEY         python -c "import secrets; print(secrets.token_urlsafe(64))"
#   WP_ENCRYPTION_KEY  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   ADMIN_PASSWORD     python -c "import secrets; print(secrets.token_urlsafe(18))"
# ============================================================================

# --- Profilo --------------------------------------------------------------
# OBBLIGATORIO: deve essere "production" per attivare i validator di sicurezza.
ENV=production

# --- Dominio pubblico & TLS (Traefik + Let's Encrypt) ---------------------
# OBBLIGATORIO: dominio completo a cui sarà raggiungibile GSI.
DOMAIN=gsi.cliente.example

# OBBLIGATORIO: email per Let's Encrypt (notifiche scadenza cert).
ACME_EMAIL=ops@cliente.example

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_DB=gsi
POSTGRES_USER=gsi_user
# OBBLIGATORIO: password Postgres forte (mai al default).
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Il backend consuma questa URL. Il DNS "postgres" risolve alla service name
# dentro la network compose; non serve esporre la 5432 fuori.
DATABASE_URL=postgresql+psycopg://gsi_user:change-me-strong-postgres-password@postgres:5432/gsi

# --- Backend: sicurezza ---------------------------------------------------
# OBBLIGATORIO: secret JWT. Almeno 32 caratteri (il validator richiede >=32).
SECRET_KEY=change-me-gen-with-secrets-token-urlsafe-64

# OBBLIGATORIO: chiave Fernet per cifrare wp_app_password nel DB.
WP_ENCRYPTION_KEY=change-me-gen-with-Fernet-generate-key

# Scadenze token (default: 30 min access, 7 giorni refresh).
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Backend: admin seed iniziale ----------------------------------------
# OBBLIGATORIO: email admin iniziale.
ADMIN_EMAIL=admin@cliente.example

# OBBLIGATORIO: password admin iniziale forte. Se lasciata al default, seed.py
# ne genera una random e la stampa UNA SOLA VOLTA nei log.
ADMIN_PASSWORD=change-me-strong-admin-password

# --- Backend: CORS --------------------------------------------------------
# OBBLIGATORIO: JSON array con il SOLO dominio del cliente.
# Il validator rifiuta localhost/127.0.0.1 in production.
CORS_ORIGINS=["https://gsi.cliente.example"]

# --- Backend: gunicorn ----------------------------------------------------
# Default 1 — APScheduler vive in-process: N>1 farebbe girare i job N volte.
# Sprint 6 introdurrà ARQ+Redis e permetterà di scalare in sicurezza.
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=60

# --- Integrazioni opzionali ----------------------------------------------
# Unsplash picker (vuoto = feature disabilitata).
UNSPLASH_ACCESS_KEY=

# Ollama LLM second-opinion. Vuoto = pipeline usa solo embeddings.
# Se abiliti, aggiungi il profilo --profile llm all'avvio del compose e setta:
#   OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=
