# ============================================================================
# GSI Backend — configurazione d'ambiente
# Copia questo file in `.env` e compila i valori per il tuo ambiente.
# ============================================================================

# --- Database ---
# Dev / single-process locale: SQLite
#   DATABASE_URL=sqlite:///./gsi.db
# Produzione (Postgres 14+ consigliato, driver psycopg3 sync):
#   DATABASE_URL=postgresql+psycopg://gsi_user:secret@localhost:5432/gsi
# Connection pool config (pool_size/max_overflow/pool_pre_ping) applicata
# automaticamente ai dialect non-SQLite in app/database.py.
DATABASE_URL=sqlite:///./gsi.db

# --- Security ---
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# In produzione il server rifiuterà di avviarsi con il valore di default (Sprint 1).
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# JSON array di origini consentite. In produzione elencare SOLO il dominio del cliente.
CORS_ORIGINS=["http://localhost:5173"]

# --- Admin iniziale (seed) ---
# Email dell'admin creato al primo seed.
ADMIN_EMAIL=admin@gsi.local
# Password admin. In produzione impostare una password robusta;
# se lasciata al default `admin123`, `seed.py` ne genererà una random e la stamperà.
ADMIN_PASSWORD=admin123

# --- Cifratura dati sensibili ---
# Chiave Fernet per cifrare la password app-specifica di WordPress.
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WP_ENCRYPTION_KEY=change-me-to-a-random-key

# --- Storage locale ---
# Cartella per le featured image caricate manualmente.
UPLOAD_DIR=uploads

# --- Unsplash (opzionale) ---
# API key per il picker di immagini stock. Ottenibile da: https://unsplash.com/developers
# Se vuoto, la feature è disabilitata.
UNSPLASH_ACCESS_KEY=

# --- LLM: Gemini (opzionale, raccomandato per "Pubblicazione GSI") ---
# API key Google AI Studio. Generabile gratis su https://aistudio.google.com/apikey
# Se vuoto, la generazione titolo+estratto pubblicazione cade su Ollama.
GEMINI_API_KEY=
# Modello da usare. Default `gemini-2.5-flash` (250 req/giorno free tier).
# Alternative: gemini-2.5-flash-lite (1000 RPD) | gemini-2.5-pro (~25 RPD)
GEMINI_MODEL=gemini-2.5-flash

# --- LLM: Ollama (opzionale) ---
# Base URL del servizio Ollama. Usato per `evaluate_relevance` (discovery)
# e come fallback per la pubblicazione se Gemini è down/quota esaurita.
# Es. dev locale: http://localhost:11434  |  Docker compose: http://ollama:11434
OLLAMA_BASE_URL=
